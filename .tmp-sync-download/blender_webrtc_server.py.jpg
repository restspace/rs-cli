    from aiortc.contrib.media import MediaPlayer, MediaRelay
except ImportError as e_aiortc_media:
    logging.warning(f"aiortc.contrib.media (MediaPlayer, MediaRelay) not found, video streaming from OBS will fail: {e_aiortc_media}")
    MediaPlayer = None
    MediaRelay = None

try:
    from aiohttp import web
except ImportError as e_aiohttp:
    logging.error(f"aiohttp not found, WebRTC server cannot start: {e_aiohttp}")
    web = None # Critical

try:
