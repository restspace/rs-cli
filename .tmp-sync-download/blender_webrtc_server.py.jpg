# -----------------------------------------------------------------------------
# Blender Scene Setup Functions (from blender_setup.py)
# -----------------------------------------------------------------------------
def clear_startup_scene():
    bpy.ops.object.select_all(action="SELECT")
    bpy.ops.object.delete(use_global=False)
    logging.info("Cleared default startup scene.")

def import_glb(filepath: pathlib.Path):
    if not filepath.exists():
        logging.error(f"GLB not found: {filepath}")
        # Don't sys.exit here, allow Blender to continue running, maybe with an empty scene
        return False
    logging.info(f"Importing GLB: {filepath} …")
    try:
        bpy.ops.import_scene.gltf(filepath=str(filepath))
        logging.info("GLB imported successfully.")
        return True
    except Exception as e:
        logging.error(f"Error importing GLB: {e}")
        return False

def set_cycles_renderer():
    logging.info("Setting render engine to Cycles.")
    scene = bpy.context.scene
    scene.render.engine = 'CYCLES'

    scene.render.engine = 'CYCLES' # Get from profile, default to CYCLES if missing
    scene.cycles.device = 'GPU'

    # Handle compute device setup (needs special care)
    compute_device_type = 'OPTIX'
    try:
        preferences = bpy.context.preferences
        system = preferences.addons['cycles'].preferences
        if system.compute_device_type != compute_device_type:
                system.compute_device_type = compute_device_type
                system.get_devices() # Refresh devices after changing type
                print(f"Compute Device Type set to: {system.compute_device_type}", flush=True)
                for device in system.devices:
                    # Enable devices matching the profile's compute type
                    device.use = (device.type == compute_device_type)
                    if device.use:
                        print(f"Enabling {compute_device_type} device: {device.name}", flush=True)
                # bpy.ops.wm.save_userpref() # Optional: Persist preference change
        else:
                # Ensure correct devices are enabled even if type hasn't changed
                system.get_devices()
                print(f"Compute Device Type already set to: {system.compute_device_type}", flush=True)
                for device in system.devices:
                    device.use = (device.type == compute_device_type)
                    if device.use:
                        print(f"Ensuring {compute_device_type} device is enabled: {device.name}", flush=True)

    except Exception as e:
            print(f"Warning: Could not configure {compute_device_type} devices: {e}", flush=True)


def ensure_camera():
    cams = [obj for obj in bpy.data.objects if obj.type == 'CAMERA']
    if cams:
        bpy.context.scene.camera = cams[0]
        logging.info(f"Using existing camera: {cams[0].name}")
        return cams[0]
    logging.info("No camera found, creating a new one.")
    bpy.ops.object.camera_add(align='VIEW', enter_editmode=False, location=(0, 0, 1.7))
    cam = bpy.context.active_object
    cam.rotation_euler = (0, 0, 0)  # Point camera forward (along +Y axis)
    cam.data.lens = 35
    bpy.context.scene.camera = cam
    return cam


def ensure_lighting():
    # check if there is already a sun light in the scene
    sun_light = [obj for obj in bpy.data.objects if obj.type == 'LIGHT' and obj.data.type == 'SUN']
    if sun_light:
        logging.info("Using existing sun light.")
        return sun_light[0]
    logging.info("No sun light found, creating a new one.")
    bpy.ops.object.light_add(type='SUN', location=(0, 0, 0))
    bpy.context.active_object.name = "Sun"
    return bpy.context.active_object


def set_viewport_shading_rendered():
    logging.info("Setting viewport shading to RENDERED for all 3D views.")
    for window in bpy.context.window_manager.windows:
        for area in window.screen.areas:
            if area.type == 'VIEW_3D':
                for space in area.spaces:
                    if space.type == 'VIEW_3D':
                        space.shading.type = 'RENDERED'
                        logging.info(f"Viewport shading set for area in window.") # Removed window.xid for simplicity/portability

def maximise_3d_viewport():
    """Toggle the first VIEW_3D area into full-screen, hiding UI panels.

    This gives a clean full-screen viewport presentation for remote viewing.
    If no VIEW_3D area is found (highly unlikely in the default screens), the
    function quietly returns.
    """

    for window in bpy.context.window_manager.windows:
        for area in window.screen.areas:
            if area.type != 'VIEW_3D':
                continue

            # If this area is already full-screen, skip to avoid toggling back.
            if area.ui_type == 'VIEW_3D' and window.screen.show_fullscreen:
                logging.info("3D viewport already maximised – skipping toggle.")
                return

            # Find a region of type WINDOW to satisfy operator context.
            region_win = next((r for r in area.regions if r.type == 'WINDOW'), None)
            try:
                override_kwargs = {"window": window, "area": area}
                if region_win:
                    override_kwargs["region"] = region_win
                with bpy.context.temp_override(**override_kwargs):
                    bpy.ops.screen.screen_full_area(use_hide_panels=True)
                    logging.info("Maximised 3D viewport to full-screen area.")
            except Exception as exc:
                logging.warning("Could not maximise 3D viewport: %s", exc)
            # Only attempt once.
            return

# ------------------------------------------------------------------
# Helper: switch viewport to the active camera and frame it nicely
# ------------------------------------------------------------------

def set_camera_view_and_frame():
    """Emulate NumPad 0 then Home to frame the active camera.

    After loading a scene we want the 3D View to look straight through the
    active camera with the frame fitting snugly inside the editor so remote
    viewers immediately see the final composition.  The logic below adapts
    Blender's internal Home-key behaviour for camera view by tweaking
    `view_camera_zoom`.
    """

    for window in bpy.context.window_manager.windows:
        for area in window.screen.areas:
            if area.type != 'VIEW_3D':
                continue

            try:
                space_data = area.spaces.active
                # Ensure we are in camera perspective first.
                space_data.region_3d.view_perspective = 'CAMERA'

                cam = bpy.context.scene.camera
                if cam is None:
                    logging.info("set_camera_view_and_frame: No active camera; aborting.")
                    return

                render = bpy.context.scene.render
                cam_width, cam_height = render.resolution_x, render.resolution_y
                viewport_width, viewport_height = area.width, area.height

                # Protect against division by zero in rare cases (minimised area)
                try:
                    cam_aspect = cam_width / cam_height
                    viewport_aspect = viewport_width / viewport_height
                except ZeroDivisionError:
                    logging.warning("set_camera_view_and_frame: zero-sized viewport – skipping.")
                    return

                if viewport_aspect > cam_aspect:
                    zoom_factor = int((viewport_height / cam_height) * 20) - 40
                else:
                    zoom_factor = int((viewport_width / cam_width) * 20) - 40

                # Clamp Blender's allowed range (-30 .. 30 where negative zooms in)
                zoom_factor = max(-30, min(zoom_factor, 30))

                space_data.region_3d.view_camera_zoom = -zoom_factor
                space_data.region_3d.view_camera_offset = (0.0, 0.0)

                logging.info(f"Viewport switched to CAMERA view and framed (zoom { -zoom_factor }).")
            except Exception as exc:
                logging.warning("set_camera_view_and_frame failed: %s", exc)
            # Only operate on the first VIEW_3D area we find.
            return
    logging.info("set_camera_view_and_frame: No VIEW_3D area found.")

def setup_blender_scene():
    clear_startup_scene()
    #import_glb(GLB_PATH)
    set_cycles_renderer()
    ensure_camera()
    ensure_lighting()
    set_viewport_shading_rendered()
    bpy.context.view_layer.update() # Ensure all changes are flushed
    maximise_3d_viewport()
    
    # Hide viewport overlays and gizmos for a clean view
    for window in bpy.context.window_manager.windows:
        for area in window.screen.areas:
            print(f"Area type: {area.type}", flush=True)
            if area.type == 'VIEW_3D':
                # Get the overlay and gizmo settings for this 3D viewport
                area.spaces[0].overlay.show_overlays = False
                area.spaces[0].show_gizmo = False
                # Hide all overlays (axis, grid, text, etc)
                #overlay.show_overlays = False
                # Hide the viewport text info
                area.spaces[0].show_region_header = False
    # After maximising the viewport, make sure it actually shows the active
    # camera and is nicely framed so the remote stream mirrors Blender's final
    # output accurately.
    try:
        set_camera_view_and_frame()
    except Exception as exc:
        logging.warning("Could not set camera view & frame: %s", exc)
    logging.info("Blender scene setup complete.")

