"""
Blender WebRTC Server:
- Sets up a Blender scene by loading a GLB and configuring Cycles.
- Starts an aiohttp/aiortc WebRTC server.
- Video Source: OBS Virtual Camera (requires OpenCV and relevant aiortc components).
- Data Channel: Listens for commands to be executed in Blender.

To run this script, launch Blender using a command like:
    blender.exe --gpu-backend opengl --python scripts/blender_webrtc_server.py

Ensure Blender's Python environment has: aiohttp, aiortc, opencv-python, av, pylibsrtp.
"""
import bpy
import os
import sys
import pathlib
import logging
import asyncio
import json
import platform
import time  # For potential delays if needed or data channel message timing
import threading  # Needed for server thread management
