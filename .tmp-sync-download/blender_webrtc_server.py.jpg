except ImportError as e_aiortc_core:
    logging.error(f"aiortc core components not found, WebRTC server cannot start: {e_aiortc_core}")
    RTCPeerConnection = None # Critical
    RTCSessionDescription = None
    RTCConfiguration = None
    RTCIceServer = None
    RTCDataChannel = None

if web is None or RTCPeerConnection is None:
    logging.error("Critical server libraries (aiohttp or aiortc base) failed to import. This script will not be able to run the WebRTC server. Exiting.")
    sys.exit(1) # Exit if essential server components are missing

